#include <stdio.h>
#include <stdlib.h>
#include <string.h>

struct Aluno{
    char nome[100];
    int idade;
    float nota;
};

void inserirAluno(struct Aluno *v, int *total){
    printf("Nome: ");
    scanf(" %[^\n]", v[*total].nome);

    printf("Idade: ");
    scanf("%d", &v[*total].idade);

    printf("Nota: ");
    scanf("%f", &v[*total].nota);

    (*total)++;
}

void listarAlunos(struct Aluno *v, int total){
    for(int i=0;i<total;i++){
        printf("\nAluno %d\n", i+1);
        printf("Nome: %s\n", v[i].nome);
        printf("Idade: %d\n", v[i].idade);
        printf("Nota: %.2f\n", v[i].nota);
    }
}

void buscarAluno(struct Aluno *v, int total, char nome[]){
    for(int i=0;i<total;i++){
        if(strcmp(v[i].nome, nome) == 0){
            printf("\nAluno encontrado\n");
            printf("Nome: %s\n", v[i].nome);
            printf("Idade: %d\n", v[i].idade);
            printf("Nota: %.2f\n", v[i].nota);
            return;
        }
    }
    printf("Aluno nao encontrado\n");
}

void ordenarPorNota(struct Aluno *v, int total){
    struct Aluno temp;

    for(int i=0;i<total-1;i++){
        for(int j=i+1;j<total;j++){
            if(v[i].nota < v[j].nota){
                temp = v[i];
                v[i] = v[j];
                v[j] = temp;
            }
        }
    }
}

int main(){

    int capacidade = 100;
    int total = 0;

    struct Aluno *alunos = malloc(sizeof(struct Aluno) * capacidade);

    inserirAluno(alunos, &total);
    inserirAluno(alunos, &total);
    inserirAluno(alunos, &total);

    listarAlunos(alunos, total);

    char nomeBusca[100];

    printf("\nDigite um nome para buscar: ");
    scanf(" %[^\n]", nomeBusca);

    buscarAluno(alunos, total, nomeBusca);

    ordenarPorNota(alunos, total);

    printf("\nAlunos ordenados por nota\n");
    listarAlunos(alunos, total);

    free(alunos);

    return 0;
}
